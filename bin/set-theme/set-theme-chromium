#!/bin/bash

# Path to active theme (symlink)
THEME_DIR="$HOME/.current-theme"
THEME=$(basename "$THEME_DIR") # optional, for logging

THEME_FILE="$THEME_DIR/chromium.theme"

[[ -f "$THEME_FILE" ]] || exit 0

RGB=$(<"$THEME_FILE")
HEX=$(printf '#%02x%02x%02x' ${RGB//,/ })

POLICY_FILE="/etc/chromium/policies/managed/color.json"

# Write the policy JSON
sudo mkdir -p "$(dirname "$POLICY_FILE")"
echo "{\"BrowserThemeColor\": \"$HEX\"}" | sudo tee "$POLICY_FILE" >/dev/null

# Refresh Chromium policies
if command -v chromium >/dev/null 2>&1; then
  chromium --no-startup-window --refresh-platform-policy
fi

echo "Chromium theme set to: $THEME"
