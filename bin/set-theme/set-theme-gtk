#!/bin/bash

# Path to active theme (symlink)
THEME_DIR="$HOME/.current-theme"
THEME=$(basename "$THEME_DIR") # optional, for logging

GTK_DIR="$HOME/.config/gtk-4.0"
GTK_FILE="$THEME_DIR/gtk.css"
TARGET_GTK="$GTK_DIR/gtk.css"

if [[ -f "$GTK_FILE" ]]; then
  mkdir -p "$GTK_DIR"
  ln -sf "$GTK_FILE" "$TARGET_GTK"
  echo "GTK4 set to theme: $THEME"
else
  echo "No gtk.css found in $THEME_DIR, skipping GTK4"
fi
