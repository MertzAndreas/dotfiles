#!/bin/bash

# Path to active theme (symlink)
THEME_DIR="$HOME/.current-theme"
THEME=$(basename "$THEME_DIR") # optional, for logging

WALKER_DIR="$HOME/.config/walker/themes/yours/"
THEME_CSS="$THEME_DIR/walker.css"
TARGET_CSS="$WALKER_DIR/colors.css"

[[ -f "$THEME_CSS" ]] || {
  echo "No walker.css found in $THEME_DIR, skipping Walker"
  exit 0
}

mkdir -p "$WALKER_DIR"
cp "$THEME_CSS" "$TARGET_CSS"

echo "Walker set to theme: $THEME"
