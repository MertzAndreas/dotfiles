#!/bin/bash

# Path to active theme (symlink)
THEME_DIR="$HOME/.current-theme"

SETTINGS_PATH="$HOME/.config/Code/User/settings.json"
VSCODE_JSON="$THEME_DIR/vscode.json"

if [[ ! -f "$VSCODE_JSON" ]]; then
  echo "No vscode.json found in $THEME_DIR, skipping VS Code"
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "Error: jq is required but not installed."
  exit 1
fi

# Extract the theme name and extension from vscode.json
NAME=$(jq -r '.name' "$VSCODE_JSON")
EXTENSION=$(jq -r '.extension' "$VSCODE_JSON")

# Backup current settings
cp "$SETTINGS_PATH" "$SETTINGS_PATH.bak"

# Apply new theme
jq --arg name "$NAME" '.["workbench.colorTheme"] = $name' \
  "$SETTINGS_PATH" >"$SETTINGS_PATH.tmp" &&
  mv "$SETTINGS_PATH.tmp" "$SETTINGS_PATH"

# Optionally install extension
if [[ -n "$EXTENSION" ]]; then
  code --install-extension "$EXTENSION" >/dev/null 2>&1
fi

echo "VS Code set to: $NAME"
