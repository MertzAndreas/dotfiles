#!/bin/bash

# Path to active theme (symlink)
THEME_DIR="$HOME/.current-theme"
THEME=$(basename "$THEME_DIR") # optional, for logging

TARGET_FILE="$HOME/.config/nvim/lua/plugins/theme.lua"
THEME_FILE="$THEME_DIR/neovim.lua"

[[ -f "$THEME_FILE" ]] || {
  echo "Theme not found: $THEME_FILE"
  exit 1
}

mkdir -p "$(dirname "$TARGET_FILE")"
cp "$THEME_FILE" "$TARGET_FILE"

echo "Neovim theme set to: $THEME"
