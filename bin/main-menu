#!/bin/bash

declare -A OPTIONS=(
  ["´Çú  Lock"]="hyprlock"
  ["´ÇŞ  Reboot"]="systemctl reboot"
  ["´Çæ  Shutdown"]="systemctl poweroff"
  ["¾░êå  Logout"]="swaymsg exit"
  ["¾▒ğò  Install package"]="launch-terminal install-package"
  ["¾▒ğö  Uninstall package"]="launch-terminal uninstall-package"
  ["¯şà  Configure nvim"]="configure-nvim"
  ["¾░é»  Bluetooth"]="launch-terminal bluetui"
  ["¯¬ä  Github"]="chromium https://github.com/SmartEVP8"
  ["¾░ı│  Minecraft music"]="chromium https://www.youtube.com/watch?v=yJ6Lbsmb1lY"
)

# Create the menu list
MENU=$(printf "%s\n" "${!OPTIONS[@]}")

# Show menu
SELECTION=$(echo -e "$MENU" | walker --dmenu --width 500 --minheight 1 -p "")

# Execute mapped command
[[ -n "$SELECTION" ]] && ${OPTIONS["$SELECTION"]}
