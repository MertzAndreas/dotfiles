#!/bin/bash

# Define options with glyphs
OPTIONS="яАг  Lock\nяАЮ  Reboot\nяАС  Shutdown"

# Show menu using walker
# SELECTION=$(echo -e "$OPTIONS" | vicinae --dmenu --width 500 --minheight 1 -p "юЬТ Power Options")
SELECTION=$(echo -e "$OPTIONS" | vicinae dmenu --width 500 -p " Power Options")

# Map selection to actions
case "$SELECTION" in
"яАг  Lock")
  lock-session
  ;;
"яАЮ  Reboot")
  systemctl reboot
  ;;
"яАС  Shutdown")
  systemctl poweroff
  ;;
*)
  exit 0
  ;;
esac
