#!/bin/bash

THEME_DIR="$HOME/dotfiles/themes"

# Generate menu options from folders, excluding 'current'
MENU=$(for theme in "$THEME_DIR"/*/; do
  name=$(basename "$theme")
  [[ "$name" != "current" ]] && echo "$name"
done)

# Show menu
SELECTION=$(echo "$MENU" | walker --dmenu --width 500 --minheight 1 -p "Select theme: ")

# Apply the theme
[[ -n "$SELECTION" ]] && set-theme-master "$SELECTION"
