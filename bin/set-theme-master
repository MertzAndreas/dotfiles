#!/bin/bash

THEMES_DIR="$HOME/dotfiles/themes/"
MODULES_DIR="$HOME/dotfiles/bin/set-theme/"
THEME="$1"
THEME_DIR="$THEMES_DIR/$THEME"
ACTIVE_THEME_DIR="$HOME/.current-theme"

if [[ -z "$THEME" ]]; then
  echo "usage: set-theme-master <theme_name>"
  exit 1
fi

if [[ ! -d "$THEME_DIR" ]]; then
  echo "Theme not found: $THEME"
  exit 1
fi

# update symlink
ln -sfn "$THEME_DIR" "$ACTIVE_THEME_DIR"

# run modules
for module in "$MODULES_DIR"/*; do
  [[ -f "$module" ]] || continue
  bash "$module" &
done

wait
echo "Themes applied: $THEME"
