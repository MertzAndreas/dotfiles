#!/bin/bash

# Define options with glyphs
OPTIONS="яЙА  Power Saver\nяЙВ  Balanced\nяЙБ  Performance"

# Show menu using walker
SELECTION=$(echo -e "$OPTIONS" | walker --dmenu --width 500 --minheight 1 -p "тЪб Power Mode")

# Map selection to power profile
case "$SELECTION" in
"яЙА  Power Saver")
  powerprofilesctl set power-saver
  ;;
"яЙВ  Balanced")
  powerprofilesctl set balanced
  ;;
"яЙБ  Performance")
  powerprofilesctl set performance
  ;;
*)
  exit 0
  ;;
esac

# Confirmation notification
notify-send "ЁЯФЛ Power Profile" "Set to: $SELECTION"
